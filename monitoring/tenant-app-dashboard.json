{
  "displayName": "Group H - Tenant App Monitoring",
  "gridLayout": {
    "columns": "2",
    "widgets": [
      {
        "title": "Container CPU usage (cores) by namespace",
        "xyChart": {
          "dataSets": [
            {
              "plotType": "LINE",
              "targetAxis": "Y1",
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "crossSeriesReducer": "REDUCE_SUM",
                    "groupByFields": [
                      "resource.label.\"namespace_name\""
                    ],
                    "perSeriesAligner": "ALIGN_RATE"
                  },
                  "filter": "metric.type=\"kubernetes.io/container/cpu/core_usage_time\" resource.type=\"k8s_container\""
                }
              }
            }
          ]
        }
      },
      {
        "title": "Container memory used (bytes) by namespace",
        "xyChart": {
          "dataSets": [
            {
              "plotType": "LINE",
              "targetAxis": "Y1",
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "crossSeriesReducer": "REDUCE_SUM",
                    "groupByFields": [
                      "resource.label.\"namespace_name\""
                    ],
                    "perSeriesAligner": "ALIGN_MEAN"
                  },
                  "filter": "metric.type=\"kubernetes.io/container/memory/used_bytes\" resource.type=\"k8s_container\""
                }
              }
            }
          ]
        }
      },
      {
        "title": "Container restarts by container (healthiness)",
        "xyChart": {
          "dataSets": [
            {
              "plotType": "STACKED_BAR",
              "targetAxis": "Y1",
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "aggregation": {
                    "alignmentPeriod": "300s",
                    "crossSeriesReducer": "REDUCE_SUM",
                    "groupByFields": [
                      "resource.label.\"container_name\""
                    ],
                    "perSeriesAligner": "ALIGN_MAX"
                  },
                  "filter": "metric.type=\"kubernetes.io/container/restart_count\" resource.type=\"k8s_container\""
                }
              }
            }
          ]
        }
      },
      {
        "title": "Running pods by namespace",
        "xyChart": {
          "dataSets": [
            {
              "plotType": "LINE",
              "targetAxis": "Y1",
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "crossSeriesReducer": "REDUCE_COUNT",
                    "groupByFields": [
                      "resource.label.\"namespace_name\""
                    ],
                    "perSeriesAligner": "ALIGN_MEAN"
                  },
                  "filter": "metric.type=\"kubernetes.io/container/uptime\" resource.type=\"k8s_container\""
                }
              }
            }
          ]
        }
      }
    ]
  }
}
